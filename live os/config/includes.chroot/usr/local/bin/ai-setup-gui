#!/usr/bin/env python3
import json
import os
import re
import socket
import subprocess
import threading

import gi

gi.require_version("Gtk", "3.0")
from gi.repository import GLib, Gtk


def run(command, timeout=12):
    try:
        result = subprocess.run(
            command,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=timeout,
        )
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except Exception as exc:
        return 1, "", str(exc)


def nmcli(*args, timeout=12):
    return run(["nmcli", *args], timeout=timeout)


def is_online():
    code, _, _ = run(["nm-online", "-q", "-t", "3"], timeout=5)
    if code == 0:
        return True
    code, out, _ = nmcli("-t", "-f", "STATE", "general")
    return code == 0 and out == "connected"


def local_ip_probe():
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.connect(("1.1.1.1", 80))
        address = sock.getsockname()[0]
        sock.close()
        return address
    except OSError:
        return "Unavailable"


def live_ssh_password():
    try:
        with open("/run/ai-live-password", "r", encoding="utf-8") as password_file:
            password = password_file.read().strip()
        return password or "Unavailable"
    except OSError:
        return "Unavailable"


def redact_secret(text, secret=""):
    redacted = str(text)
    if secret:
        redacted = redacted.replace(secret, "[redacted]")
    redacted = re.sub(r"\bcr_[A-Za-z0-9_=-]{12,}\b", "[redacted]", redacted)
    redacted = re.sub(r"\b[0-9A-Za-z_-]{24,}\b", "[redacted]", redacted)
    return redacted


class SetupWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title="AI Live Setup")
        self.set_decorated(False)
        self.fullscreen()
        self.set_name("root")
        self.connect("destroy", Gtk.main_quit)

        self.stack = Gtk.Stack(transition_type=Gtk.StackTransitionType.CROSSFADE, transition_duration=260)
        self.add(self.stack)

        self.network_box = None
        self.password_entry = None
        self.status_label = None
        self.details_grid = None
        self.ngrok_auth_token = ""
        self.ngrok_listener = None
        self.ngrok_url = ""
        self.ngrok_status_label = None
        self.ngrok_endpoint_label = None
        self.ngrok_settings_label = None
        self.ngrok_start_button = None
        self.ngrok_configure_button = None

        self.build_network_screen()
        self.build_details_screen()
        self.apply_css()

        self.refresh_networks()
        self.check_initial_connection()
        GLib.timeout_add_seconds(4, self.poll_connection)

    def apply_css(self):
        css = b"""
        #root {
          background-color: #0f172a;
          color: #e5e7eb;
          font-family: "DejaVu Sans";
        }
        .shell {
          background-color: #0f766e;
        }
        .panel {
          background: rgba(255, 255, 255, 0.94);
          border-radius: 8px;
          color: #111827;
        }
        .eyebrow {
          color: #0f766e;
          font-size: 12px;
          font-weight: 700;
        }
        .title {
          color: #111827;
          font-size: 34px;
          font-weight: 800;
        }
        .subtitle {
          color: #4b5563;
          font-size: 15px;
        }
        .section-title {
          color: #111827;
          font-size: 16px;
          font-weight: 700;
        }
        .muted {
          color: #6b7280;
          font-size: 13px;
        }
        button {
          border-radius: 6px;
          border: 1px solid #d1d5db;
          background: #ffffff;
          color: #111827;
          padding: 10px 14px;
          font-weight: 700;
        }
        button:hover {
          background: #f3f4f6;
        }
