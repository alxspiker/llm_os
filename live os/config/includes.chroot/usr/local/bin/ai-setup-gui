    def collect_details(self):
        code, general, _ = nmcli("-t", "-f", "STATE,CONNECTIVITY", "general")
        code, devices, _ = nmcli("-t", "-f", "DEVICE,TYPE,STATE,CONNECTION", "device", "status")
        code, ip_json, _ = run(["ip", "-j", "addr", "show"], timeout=5)

        active = "Unavailable"
        connection = "Unavailable"
        for line in devices.splitlines():
            parts = line.split(":")
            if len(parts) >= 4 and parts[2] == "connected":
                active = f"{parts[0]} ({parts[1]})"
                connection = parts[3]
                break

        ipv4 = local_ip_probe()
        ipv6 = "Unavailable"
        try:
            data = json.loads(ip_json)
            for iface in data:
                for addr in iface.get("addr_info", []):
                    if addr.get("family") == "inet" and ipv4 == "Unavailable":
                        ipv4 = addr.get("local", ipv4)
                    if addr.get("family") == "inet6" and not addr.get("local", "").startswith("fe80"):
                        ipv6 = addr.get("local")
        except Exception:
            pass

        hostname = socket.gethostname()
        return [
            ("Status", general.replace(":", " / ") if general else "Connected"),
            ("Hostname", hostname),
            ("SSH User", "live"),
            ("SSH Password", live_ssh_password()),
            ("Active Interface", active),
            ("Connection", connection),
            ("IPv4 Address", ipv4),
            ("IPv6 Address", ipv6),
        ]

    def show_details(self):
        for child in self.details_grid.get_children():
            self.details_grid.remove(child)
        for row, (key, value) in enumerate(self.collect_details()):
            key_label = self.label(key.upper(), "detail-key")
            value_label = self.label(value, "detail-value")
            value_label.set_line_wrap(True)
            value_label.set_line_wrap_mode(Pango.WrapMode.CHAR)
            value_label.set_max_width_chars(22)
            value_label.set_size_request(260, -1)
            value_label.set_selectable(True)
            self.details_grid.attach(key_label, 0, row, 1, 1)
            self.details_grid.attach(value_label, 1, row, 1, 1)
        self.details_grid.show_all()
        self.update_ngrok_ui()
        self.stack.set_visible_child_name("details")
        self.maybe_autostart_ngrok()

    def mcp_settings_text(self):
        endpoint = self.ngrok_url or "not-started"
        return json.dumps(
            {
                "mcpServers": {
                    "linux-laptop": {
                        "transport": "http",
                        "url": f"{endpoint}/mcp",
                        "forwardedLocalPort": 80,
                    }
                }
            },
            indent=2,
        )

    def update_ngrok_ui(self, status=None):
        if status and self.ngrok_status_label:
            self.ngrok_status_label.set_text(status)
        if self.ngrok_endpoint_label:
            endpoint = self.ngrok_url if self.ngrok_url else "Not started"
            self.ngrok_endpoint_label.set_text(f"Public endpoint: {endpoint}")
        if self.ngrok_settings_label:
            self.ngrok_settings_label.set_text(self.mcp_settings_text())
        if self.ngrok_start_button:
            self.ngrok_start_button.set_label("Stop ngrok" if self.ngrok_listener else "Start ngrok")

    def config_candidates(self):
        for root in mounted_roots():
            yield root, os.path.join(root, CONFIG_NAME)

    def find_config_path(self, require_writable=False):
        writable_fallback = None
        for root, path in self.config_candidates():
            if os.path.exists(path) and (not require_writable or os.access(path, os.W_OK)):
                return path
            if writable_fallback is None and is_writable_dir(root):
                writable_fallback = path
        if require_writable:
            return writable_fallback
        return None

    def load_config(self):
        path = self.find_config_path(require_writable=False)
        if not path:
            self.config_status = f"{CONFIG_NAME} not found on the boot USB."
            return

        parser = configparser.ConfigParser()
        try:
            parser.read(path)
            self.config_path = path
            self.ngrok_auth_token = parser.get("ngrok", "authtoken", fallback="").strip()
            self.ngrok_autostart = parser.getboolean("ngrok", "autostart", fallback=False)
            self.wifi_ssid = parser.get("wifi", "ssid", fallback="").strip()
            self.wifi_passkey = parser.get("wifi", "passkey", fallback="")
            self.config_status = f"Loaded config from {path}"
        except Exception as exc:
            self.config_status = f"Could not read {CONFIG_NAME}: {exc}"

    def save_config(self, token=None, autostart=None):
        path = self.config_path if self.config_path and os.access(self.config_path, os.W_OK) else None
        if not path:
            path = self.find_config_path(require_writable=True)
        if not path:
            return None, f"No writable USB root found for {CONFIG_NAME}."

        parser = configparser.ConfigParser()
        parser["ngrok"] = {
            "authtoken": self.ngrok_auth_token if token is None else token,
            "autostart": "true" if (self.ngrok_autostart if autostart is None else autostart) else "false",
        }
        parser["wifi"] = {
            "ssid": self.wifi_ssid,
            "passkey": self.wifi_passkey,
        }
        try:
            with open(path, "w", encoding="utf-8") as config_file:
                parser.write(config_file)
            try:
                os.chmod(path, 0o600)
            except OSError:
                pass
            self.config_path = path
            self.config_status = f"Saved config to {path}"
            return path, None
        except Exception as exc:
            return None, f"Could not save {CONFIG_NAME}: {exc}"

    def maybe_autoconnect_wifi(self):
        if self.wifi_autoconnect_attempted or not self.wifi_ssid:
            return
        self.wifi_autoconnect_attempted = True
        if self.status_spinner:
            self.status_spinner.start()
        self.status_label.set_text(f"Connecting to saved Wi-Fi network {self.wifi_ssid}...")

        def worker():
            nmcli("radio", "wifi", "on", timeout=6)
            command = ["nmcli", "device", "wifi", "connect", self.wifi_ssid]
            if self.wifi_passkey:
                command.extend(["password", self.wifi_passkey])
            code, out, err = run(command, timeout=30)
            GLib.idle_add(self.after_autoconnect_wifi, code, out, err)

        threading.Thread(target=worker, daemon=True).start()

    def after_autoconnect_wifi(self, code, out, err):
        if self.status_spinner:
            self.status_spinner.stop()
        if code == 0 or is_online():
            self.status_label.set_text("Connected to saved Wi-Fi network.")
            self.show_details()
        else:
            self.status_label.set_text(err or out or "Could not connect to the saved Wi-Fi network.")
        return False

    def maybe_autostart_ngrok(self):
        if self.ngrok_autostart_attempted or self.ngrok_listener:
            return
        if not self.ngrok_autostart or not self.ngrok_auth_token:
            return
        if not is_online():
            return
        self.ngrok_autostart_attempted = True
        self.start_ngrok(interactive=False, autostart=True)

    def load_ngrok(self):
        try:
            import ngrok

            return ngrok, None
        except Exception as exc:
            return None, str(exc)

    def open_ngrok_dialog(self):
        dialog = Gtk.Dialog(title="Ngrok auth token", transient_for=self, flags=0)
        dialog.add_button("Cancel", Gtk.ResponseType.CANCEL)
        dialog.add_button("Save", Gtk.ResponseType.OK)
        dialog.set_default_size(480, 180)

        content = dialog.get_content_area()
        content.set_spacing(10)
        content.set_margin_top(16)
        content.set_margin_bottom(16)
        content.set_margin_start(16)
        content.set_margin_end(16)

        content.pack_start(self.label("Enter ngrok authtoken", "section-title"), False, False, 0)
        token_entry = Gtk.Entry()
        token_entry.set_visibility(False)
        token_entry.set_placeholder_text("Authtoken from dashboard, not an API key")
        token_entry.set_text(self.ngrok_auth_token)
        content.pack_start(token_entry, False, False, 0)

        autostart_check = Gtk.CheckButton(label="Autostart ngrok after network connects")
        autostart_check.set_active(self.ngrok_autostart)
        content.pack_start(autostart_check, False, False, 0)

        test_status = self.label(f"Test creates a temporary tunnel to localhost:{NGROK_PORT}. {self.config_status}", "muted")
        content.pack_start(test_status, False, False, 0)

        test_button = Gtk.Button(label="Test connection")
        test_button.connect("clicked", lambda _button: self.test_ngrok_token(token_entry.get_text(), test_status, test_button))
        content.pack_start(test_button, False, False, 0)

        dialog.show_all()
        response = dialog.run()
        if response == Gtk.ResponseType.OK:
            self.ngrok_auth_token = token_entry.get_text().strip()
            self.ngrok_autostart = autostart_check.get_active()
            self.ngrok_autostart_attempted = False
            _path, error = self.save_config(self.ngrok_auth_token, self.ngrok_autostart)
            if error:
                self.update_ngrok_ui(error)
            else:
                self.update_ngrok_ui(self.config_status)
                self.maybe_autostart_ngrok()
        dialog.destroy()

    def test_ngrok_token(self, token, status_label, test_button):
        token = token.strip()
        if not token:
            status_label.set_text("Enter an auth token first.")
            return

        status_label.set_text("Testing ngrok connection...")
        test_button.set_sensitive(False)

        def worker():
            ngrok, error = self.load_ngrok()
            if error:
                GLib.idle_add(self.finish_ngrok_test, status_label, test_button, f"ngrok package unavailable: {error}")
                return
            try:
                listener = ngrok.forward(NGROK_PORT, authtoken=token)
                url = listener.url()
                ngrok.disconnect(url)
                GLib.idle_add(self.finish_ngrok_test, status_label, test_button, f"Connection OK: {url}")
            except Exception as exc:
                error = redact_secret(exc, token)
                GLib.idle_add(self.finish_ngrok_test, status_label, test_button, f"Connection failed: {error}")

        threading.Thread(target=worker, daemon=True).start()

    def finish_ngrok_test(self, status_label, test_button, message):
        status_label.set_text(message)
        test_button.set_sensitive(True)
        return False

    def toggle_ngrok(self):
        if self.ngrok_listener:
            self.stop_ngrok()
        else:
            self.start_ngrok()

    def start_ngrok(self, interactive=True, autostart=False):
        if not self.ngrok_auth_token:
            if not interactive:
                self.update_ngrok_ui(f"Ngrok autostart skipped: no token in {CONFIG_NAME}.")
                return
            self.open_ngrok_dialog()
            if not self.ngrok_auth_token:
                self.update_ngrok_ui("Ngrok token is required before starting.")
                return

        self.ngrok_start_button.set_sensitive(False)
        action = "Autostarting" if autostart else "Starting"
        self.update_ngrok_ui(f"{action} ngrok tunnel to localhost:{NGROK_PORT}...")

        def worker():
            ngrok, error = self.load_ngrok()
            if error:
                GLib.idle_add(self.finish_ngrok_start, None, "", f"ngrok package unavailable: {error}")
                return
            try:
                listener = ngrok.forward(NGROK_PORT, authtoken=self.ngrok_auth_token)
                GLib.idle_add(self.finish_ngrok_start, listener, listener.url(), "Ngrok is running.")
            except Exception as exc:
                error = redact_secret(exc, self.ngrok_auth_token)
                GLib.idle_add(self.finish_ngrok_start, None, "", f"Could not start ngrok: {error}")

        threading.Thread(target=worker, daemon=True).start()

    def finish_ngrok_start(self, listener, url, message):
        self.ngrok_listener = listener
        self.ngrok_url = url
        self.ngrok_start_button.set_sensitive(True)
        self.update_ngrok_ui(message)
        return False

    def stop_ngrok(self):
        listener = self.ngrok_listener
        url = self.ngrok_url
        self.ngrok_start_button.set_sensitive(False)
        self.update_ngrok_ui("Stopping ngrok...")

        def worker():
            ngrok, error = self.load_ngrok()
            try:
                if listener:
                    listener.close()
                elif ngrok and url:
                    ngrok.disconnect(url)
            except Exception:
                pass
            GLib.idle_add(self.finish_ngrok_stop)

        threading.Thread(target=worker, daemon=True).start()

    def finish_ngrok_stop(self):
        self.ngrok_listener = None
        self.ngrok_url = ""
        self.ngrok_start_button.set_sensitive(True)
        self.update_ngrok_ui("Ngrok is stopped.")
        return False


if __name__ == "__main__":
    os.environ.setdefault("GDK_BACKEND", "x11")
    window = SetupWindow()
    window.show_all()
    Gtk.main()
