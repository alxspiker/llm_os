        self.add(self.stack)

        self.network_box = None
        self.password_entry = None
        self.status_label = None
        self.status_spinner = None
        self.details_grid = None
        self.ngrok_auth_token = ""
        self.ngrok_listener = None
        self.ngrok_url = ""
        self.ngrok_status_label = None
        self.ngrok_endpoint_label = None
