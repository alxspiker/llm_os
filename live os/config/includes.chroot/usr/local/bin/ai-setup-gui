        """
        provider = Gtk.CssProvider()
        provider.load_from_data(css)
        Gtk.StyleContext.add_provider_for_screen(
            self.get_screen(),
            provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

    def outer(self):
        shell = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        shell.get_style_context().add_class("shell")
        shell.set_halign(Gtk.Align.FILL)
        shell.set_valign(Gtk.Align.FILL)

        panel = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        panel.set_halign(Gtk.Align.CENTER)
        panel.set_valign(Gtk.Align.CENTER)
        panel.set_size_request(860, -1)
        panel.set_margin_top(48)
        panel.set_margin_bottom(48)
        panel.set_margin_start(32)
        panel.set_margin_end(32)
        panel.get_style_context().add_class("panel")

        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        content.set_margin_top(34)
        content.set_margin_bottom(34)
        content.set_margin_start(34)
        content.set_margin_end(34)
        panel.pack_start(content, True, True, 0)

        shell.pack_start(panel, True, True, 0)
        return shell, content

    def label(self, text, css_class, xalign=0):
        item = Gtk.Label(label=text, xalign=xalign)
        item.set_line_wrap(True)
        item.get_style_context().add_class(css_class)
        return item

    def build_network_screen(self):
        shell, panel = self.outer()
        panel.pack_start(self.label("NETWORK SETUP", "eyebrow"), False, False, 0)
        panel.pack_start(self.label("Connect this computer", "title"), False, False, 8)
        panel.pack_start(
            self.label(
                "Choose a Wi-Fi network, or plug in Ethernet. Setup will continue automatically once the computer is online.",
                "subtitle",
            ),
            False,
            False,
            0,
        )

        content = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=24)
        content.set_margin_top(28)
        panel.pack_start(content, True, True, 0)

        left = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        content.pack_start(left, True, True, 0)
        left.pack_start(self.label("Available Wi-Fi", "section-title"), False, False, 0)

        scroller = Gtk.ScrolledWindow()
        scroller.set_min_content_height(280)
        scroller.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.network_box = Gtk.ListBox()
        self.network_box.set_selection_mode(Gtk.SelectionMode.SINGLE)
        scroller.add(self.network_box)
        left.pack_start(scroller, True, True, 0)

        actions = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        left.pack_start(actions, False, False, 0)
        refresh = Gtk.Button(label="Refresh")
        refresh.connect("clicked", lambda _button: self.refresh_networks())
        actions.pack_start(refresh, False, False, 0)

        right = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        right.set_size_request(300, -1)
        content.pack_start(right, False, False, 0)
        right.pack_start(self.label("Password", "section-title"), False, False, 0)
        self.password_entry = Gtk.Entry()
        self.password_entry.set_visibility(False)
        self.password_entry.set_placeholder_text("Wi-Fi password")
        self.password_entry.connect("activate", lambda _entry: self.connect_selected())
        right.pack_start(self.password_entry, False, False, 0)

        connect = Gtk.Button(label="Connect")
        connect.get_style_context().add_class("suggested-action")
        connect.connect("clicked", lambda _button: self.connect_selected())
        right.pack_start(connect, False, False, 0)

        skip = Gtk.Button(label="Continue")
        skip.connect("clicked", lambda _button: self.show_details())
        right.pack_start(skip, False, False, 0)

        self.status_label = self.label("Waiting for a network connection...", "muted")
        self.status_label.set_margin_top(8)
        right.pack_start(self.status_label, False, False, 0)

        self.stack.add_named(shell, "network")

    def network_row(self, ssid, signal, security):
        row = Gtk.ListBoxRow()
        row.ssid = ssid
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        box.set_border_width(10)
        row.add(box)

        text = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        box.pack_start(text, True, True, 0)
        name = self.label(ssid or "Hidden network", "section-title")
        text.pack_start(name, False, False, 0)
        meta = self.label(f"Signal {signal or 'unknown'}%  {security or 'Open network'}", "muted")
        text.pack_start(meta, False, False, 0)
        return row

    def refresh_networks(self):
        self.status_label.set_text("Scanning for Wi-Fi networks...")
        for child in self.network_box.get_children():
            self.network_box.remove(child)

        def worker():
            nmcli("radio", "wifi", "on", timeout=6)
            nmcli("device", "wifi", "rescan", timeout=8)
            code, out, err = nmcli("-t", "-f", "SSID,SIGNAL,SECURITY", "device", "wifi", "list", timeout=10)
            GLib.idle_add(self.populate_networks, code, out, err)

        threading.Thread(target=worker, daemon=True).start()

    def populate_networks(self, code, out, err):
        seen = set()
        if code == 0:
            for line in out.splitlines():
                parts = line.split(":")
                ssid = parts[0].replace("\\:", ":").strip()
                if not ssid or ssid in seen:
                    continue
                signal = parts[1] if len(parts) > 1 else ""
                security = parts[2] if len(parts) > 2 else ""
                seen.add(ssid)
                self.network_box.add(self.network_row(ssid, signal, security))
        if seen:
            self.status_label.set_text("Select a network and enter its password.")
        else:
            self.status_label.set_text(err or "No Wi-Fi networks found. Ethernet is also supported.")
        self.network_box.show_all()
        return False

    def connect_selected(self):
        row = self.network_box.get_selected_row()
        if row is None:
            self.status_label.set_text("Select a Wi-Fi network first.")
            return
        ssid = row.ssid
        password = self.password_entry.get_text()
        self.status_label.set_text(f"Connecting to {ssid}...")

        def worker():
            command = ["nmcli", "device", "wifi", "connect", ssid]
            if password:
                command.extend(["password", password])
            code, out, err = run(command, timeout=30)
            GLib.idle_add(self.after_connect, code, out, err)

        threading.Thread(target=worker, daemon=True).start()

    def after_connect(self, code, out, err):
        if code == 0 or is_online():
            self.status_label.set_text("Connected.")
            self.show_details()
        else:
            self.status_label.set_text(err or out or "Connection failed. Check the password and try again.")
        return False

    def check_initial_connection(self):
        if is_online():
            self.show_details()
        else:
            self.stack.set_visible_child_name("network")

    def poll_connection(self):
        if self.stack.get_visible_child_name() == "network" and is_online():
            self.show_details()
        return True

    def build_details_screen(self):
        shell, panel = self.outer()
        panel.pack_start(self.label("CONNECTED", "eyebrow"), False, False, 0)
        panel.pack_start(self.label("Computer network details", "title"), False, False, 8)
        panel.pack_start(
            self.label("This computer is online. Use these details to reach it from another device on the network.", "subtitle"),
            False,
            False,
            0,
        )

        main = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=28)
        main.set_margin_top(26)
        panel.pack_start(main, False, False, 0)

        left = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        main.pack_start(left, False, False, 0)

        self.details_grid = Gtk.Grid(column_spacing=24, row_spacing=16)
        left.pack_start(self.details_grid, False, False, 0)

        buttons = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        buttons.set_margin_top(22)
        left.pack_start(buttons, False, False, 0)

        refresh = Gtk.Button(label="Refresh")
        refresh.connect("clicked", lambda _button: self.show_details())
        buttons.pack_start(refresh, False, False, 0)

        close = Gtk.Button(label="Close")
        close.connect("clicked", lambda _button: Gtk.main_quit())
        buttons.pack_start(close, False, False, 0)

        ngrok_section = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        ngrok_section.set_size_request(360, -1)
        main.pack_start(ngrok_section, False, False, 0)
        ngrok_section.pack_start(self.label("Model context protocol server settings", "section-title"), False, False, 0)

        self.ngrok_status_label = self.label("Ngrok is stopped.", "muted")
        ngrok_section.pack_start(self.ngrok_status_label, False, False, 0)

        self.ngrok_endpoint_label = self.label("Public endpoint: Not started", "detail-value")
        ngrok_section.pack_start(self.ngrok_endpoint_label, False, False, 0)

        self.ngrok_settings_label = self.label("", "code")
        ngrok_section.pack_start(self.ngrok_settings_label, False, False, 0)

        ngrok_buttons = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        ngrok_section.pack_start(ngrok_buttons, False, False, 0)

        self.ngrok_configure_button = Gtk.Button(label="Ngrok token")
        self.ngrok_configure_button.connect("clicked", lambda _button: self.open_ngrok_dialog())
        ngrok_buttons.pack_start(self.ngrok_configure_button, False, False, 0)

        self.ngrok_start_button = Gtk.Button(label="Start ngrok")
        self.ngrok_start_button.get_style_context().add_class("suggested-action")
        self.ngrok_start_button.connect("clicked", lambda _button: self.toggle_ngrok())
        ngrok_buttons.pack_start(self.ngrok_start_button, False, False, 0)

        self.stack.add_named(shell, "details")
        self.update_ngrok_ui()

    def collect_details(self):
        code, general, _ = nmcli("-t", "-f", "STATE,CONNECTIVITY", "general")
        code, devices, _ = nmcli("-t", "-f", "DEVICE,TYPE,STATE,CONNECTION", "device", "status")
        code, ip_json, _ = run(["ip", "-j", "addr", "show"], timeout=5)

        active = "Unavailable"
        connection = "Unavailable"
        for line in devices.splitlines():
            parts = line.split(":")
            if len(parts) >= 4 and parts[2] == "connected":
                active = f"{parts[0]} ({parts[1]})"
                connection = parts[3]
                break

        ipv4 = local_ip_probe()
        ipv6 = "Unavailable"
        try:
            data = json.loads(ip_json)
            for iface in data:
                for addr in iface.get("addr_info", []):
                    if addr.get("family") == "inet" and ipv4 == "Unavailable":
                        ipv4 = addr.get("local", ipv4)
                    if addr.get("family") == "inet6" and not addr.get("local", "").startswith("fe80"):
                        ipv6 = addr.get("local")
        except Exception:
            pass

        hostname = socket.gethostname()
        return [
            ("Status", general.replace(":", " / ") if general else "Connected"),
            ("Hostname", hostname),
            ("SSH User", "live"),
            ("SSH Password", live_ssh_password()),
            ("Active Interface", active),
            ("Connection", connection),
            ("IPv4 Address", ipv4),
            ("IPv6 Address", ipv6),
        ]

    def show_details(self):
        for child in self.details_grid.get_children():
            self.details_grid.remove(child)
        for row, (key, value) in enumerate(self.collect_details()):
            key_label = self.label(key.upper(), "detail-key")
            value_label = self.label(value, "detail-value")
            self.details_grid.attach(key_label, 0, row, 1, 1)
            self.details_grid.attach(value_label, 1, row, 1, 1)
        self.details_grid.show_all()
        self.update_ngrok_ui()
        self.stack.set_visible_child_name("details")

    def mcp_settings_text(self):
        endpoint = self.ngrok_url or "not-started"
        return json.dumps(
            {
                "mcpServers": {
                    "linux-laptop": {
                        "transport": "http",
                        "url": f"{endpoint}/mcp",
                        "forwardedLocalPort": 80,
                    }
                }
            },
            indent=2,
        )

    def update_ngrok_ui(self, status=None):
        if status and self.ngrok_status_label:
            self.ngrok_status_label.set_text(status)
        if self.ngrok_endpoint_label:
            endpoint = self.ngrok_url if self.ngrok_url else "Not started"
            self.ngrok_endpoint_label.set_text(f"Public endpoint: {endpoint}")
        if self.ngrok_settings_label:
            self.ngrok_settings_label.set_text(self.mcp_settings_text())
        if self.ngrok_start_button:
            self.ngrok_start_button.set_label("Stop ngrok" if self.ngrok_listener else "Start ngrok")

    def load_ngrok(self):
        try:
            import ngrok

            return ngrok, None
        except Exception as exc:
            return None, str(exc)

    def open_ngrok_dialog(self):
        dialog = Gtk.Dialog(title="Ngrok auth token", transient_for=self, flags=0)
        dialog.add_button("Cancel", Gtk.ResponseType.CANCEL)
        dialog.add_button("Save", Gtk.ResponseType.OK)
        dialog.set_default_size(480, 180)

        content = dialog.get_content_area()
        content.set_spacing(10)
        content.set_margin_top(16)
        content.set_margin_bottom(16)
        content.set_margin_start(16)
        content.set_margin_end(16)

        content.pack_start(self.label("Enter ngrok authtoken", "section-title"), False, False, 0)
        token_entry = Gtk.Entry()
        token_entry.set_visibility(False)
        token_entry.set_placeholder_text("Authtoken from dashboard, not an API key")
        token_entry.set_text(self.ngrok_auth_token)
        content.pack_start(token_entry, False, False, 0)

        test_status = self.label("Test creates a temporary tunnel to localhost:80.", "muted")
        content.pack_start(test_status, False, False, 0)

        test_button = Gtk.Button(label="Test connection")
        test_button.connect("clicked", lambda _button: self.test_ngrok_token(token_entry.get_text(), test_status, test_button))
        content.pack_start(test_button, False, False, 0)

        dialog.show_all()
        response = dialog.run()
        if response == Gtk.ResponseType.OK:
            self.ngrok_auth_token = token_entry.get_text().strip()
            self.update_ngrok_ui("Ngrok token saved for this live session.")
        dialog.destroy()

    def test_ngrok_token(self, token, status_label, test_button):
        token = token.strip()
        if not token:
            status_label.set_text("Enter an auth token first.")
            return

        status_label.set_text("Testing ngrok connection...")
        test_button.set_sensitive(False)

        def worker():
            ngrok, error = self.load_ngrok()
            if error:
                GLib.idle_add(self.finish_ngrok_test, status_label, test_button, f"ngrok package unavailable: {error}")
                return
            try:
                listener = ngrok.forward(80, authtoken=token)
                url = listener.url()
                ngrok.disconnect(url)
                GLib.idle_add(self.finish_ngrok_test, status_label, test_button, f"Connection OK: {url}")
            except Exception as exc:
                error = redact_secret(exc, token)
                GLib.idle_add(self.finish_ngrok_test, status_label, test_button, f"Connection failed: {error}")

        threading.Thread(target=worker, daemon=True).start()

    def finish_ngrok_test(self, status_label, test_button, message):
        status_label.set_text(message)
        test_button.set_sensitive(True)
        return False

    def toggle_ngrok(self):
        if self.ngrok_listener:
            self.stop_ngrok()
        else:
            self.start_ngrok()

    def start_ngrok(self):
        if not self.ngrok_auth_token:
            self.open_ngrok_dialog()
            if not self.ngrok_auth_token:
                self.update_ngrok_ui("Ngrok token is required before starting.")
                return

        self.ngrok_start_button.set_sensitive(False)
        self.update_ngrok_ui("Starting ngrok tunnel to localhost:80...")

        def worker():
            ngrok, error = self.load_ngrok()
            if error:
                GLib.idle_add(self.finish_ngrok_start, None, "", f"ngrok package unavailable: {error}")
                return
            try:
                listener = ngrok.forward(80, authtoken=self.ngrok_auth_token)
                GLib.idle_add(self.finish_ngrok_start, listener, listener.url(), "Ngrok is running.")
            except Exception as exc:
                error = redact_secret(exc, self.ngrok_auth_token)
                GLib.idle_add(self.finish_ngrok_start, None, "", f"Could not start ngrok: {error}")

        threading.Thread(target=worker, daemon=True).start()

    def finish_ngrok_start(self, listener, url, message):
        self.ngrok_listener = listener
        self.ngrok_url = url
        self.ngrok_start_button.set_sensitive(True)
        self.update_ngrok_ui(message)
        return False

    def stop_ngrok(self):
        listener = self.ngrok_listener
        url = self.ngrok_url
        self.ngrok_start_button.set_sensitive(False)
        self.update_ngrok_ui("Stopping ngrok...")

        def worker():
            ngrok, error = self.load_ngrok()
            try:
                if listener:
                    listener.close()
                elif ngrok and url:
                    ngrok.disconnect(url)
            except Exception:
                pass
            GLib.idle_add(self.finish_ngrok_stop)

        threading.Thread(target=worker, daemon=True).start()

    def finish_ngrok_stop(self):
        self.ngrok_listener = None
        self.ngrok_url = ""
        self.ngrok_start_button.set_sensitive(True)
        self.update_ngrok_ui("Ngrok is stopped.")
        return False


if __name__ == "__main__":
    os.environ.setdefault("GDK_BACKEND", "x11")
    window = SetupWindow()
    window.show_all()
    Gtk.main()
