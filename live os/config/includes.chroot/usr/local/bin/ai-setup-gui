        self.ngrok_autostart_attempted = False
        self.wifi_ssid = ""
        self.wifi_passkey = ""
        self.wifi_autoconnect_attempted = False
        self.config_path = None
        self.config_status = "No USB config found."

        self.load_config()

        self.build_network_screen()
        self.build_details_screen()
        self.apply_css()

        self.refresh_networks()
        self.check_initial_connection()
        GLib.timeout_add_seconds(4, self.poll_connection)

