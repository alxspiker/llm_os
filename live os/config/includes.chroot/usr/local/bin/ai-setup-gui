#!/usr/bin/env python3
import configparser
import json
import os
import re
import socket
import subprocess
import threading

import gi

gi.require_version("Gtk", "3.0")
from gi.repository import GLib, Gtk, Pango

CONFIG_NAME = "AI-LIVE.CFG"
NGROK_PORT = 80


def run(command, timeout=12):
    try:
        result = subprocess.run(
            command,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=timeout,
        )
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except Exception as exc:
        return 1, "", str(exc)


def nmcli(*args, timeout=12):
    return run(["nmcli", *args], timeout=timeout)


def is_online():
    code, _, _ = run(["nm-online", "-q", "-t", "3"], timeout=5)
    if code == 0:
        return True
    code, out, _ = nmcli("-t", "-f", "STATE", "general")
    return code == 0 and out == "connected"


def local_ip_probe():
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.connect(("1.1.1.1", 80))
        address = sock.getsockname()[0]
        sock.close()
        return address
    except OSError:
        return "Unavailable"


def live_ssh_password():
    try:
        with open("/run/ai-live-password", "r", encoding="utf-8") as password_file:
            password = password_file.read().strip()
        return password or "Unavailable"
    except OSError:
        return "Unavailable"


def redact_secret(text, secret=""):
    redacted = str(text)
    if secret:
        redacted = redacted.replace(secret, "[redacted]")
    redacted = re.sub(r"\bcr_[A-Za-z0-9_=-]{12,}\b", "[redacted]", redacted)
    redacted = re.sub(r"\b[0-9A-Za-z_-]{24,}\b", "[redacted]", redacted)
    return redacted


def mounted_roots():
    roots = []
    for base in ("/run/live/medium", "/media", "/mnt"):
        if os.path.ismount(base):
            roots.append(base)
        elif os.path.isdir(base):
            for current, dirs, _files in os.walk(base):
                if os.path.ismount(current):
                    roots.append(current)
                    dirs[:] = []
                elif current.count(os.sep) - base.count(os.sep) >= 2:
                    dirs[:] = []
    return list(dict.fromkeys(roots))


def is_writable_dir(path):
    if not os.path.isdir(path) or not os.access(path, os.W_OK):
        return False
    probe = os.path.join(path, ".ai-live-write-test")
    try:
        with open(probe, "w", encoding="utf-8") as handle:
            handle.write("")
        os.remove(probe)
        return True
    except OSError:
        return False


